---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign public_pages = site.pages | where_exp: "item", "item.sitemap != false" %}
{% for item in public_pages %}
  {% if item.url and item.url != "/sitemap.xml" and item.url != "/robots.txt" %}
  <url>
    <loc>{{ item.url | replace: "index.html", "" | absolute_url }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
  {% endif %}
{% endfor %}
</urlset>
